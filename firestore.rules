rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- 2. Users Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid
        && incoming().email is string
        && incoming().birthdate is string
        && incoming().birthdate.size() <= 50
        && incoming().age is int
        && incoming().createdAt is timestamp
        && incoming().createdAt <= request.time;

      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'selectedVoice', 'curseMode', 'birthdate', 'age'])
        );
    }

    // --- 3. Chats Collection ---
    match /chats/{chatId} {
      allow read, list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(chatId)
        && incoming().id == chatId
        && incoming().userId == request.auth.uid
        && incoming().title is string
        && incoming().title.size() <= 200
        && incoming().createdAt is timestamp
        && incoming().createdAt <= request.time;

      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().id == existing().id
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['title']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      // --- Nested Message Subcollection ---
      match /messages/{messageId} {
        // Master Gate check: Check if parent chat document exists and belongs to the user
        function parentChatBelongsToUser() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        }

        allow read, list: if isSignedIn() && parentChatBelongsToUser();

        allow create: if isSignedIn() 
          && parentChatBelongsToUser()
          && isValidId(messageId)
          && incoming().id == messageId
          && incoming().sender in ['user', 'ai']
          && incoming().text is string
          && incoming().text.size() <= 5000
          && incoming().createdAt is timestamp
          && incoming().createdAt <= request.time;

        allow update, delete: if isSignedIn() && parentChatBelongsToUser() && false; // Messages are immutable once written
      }
    }

    // --- 4. Generations Collection ---
    match /generations/{generationId} {
      allow read, list: if isSignedIn() && (resource == null || existing().userId == request.auth.uid);

      allow create: if isSignedIn()
        && isValidId(generationId)
        && incoming().id == generationId
        && incoming().userId == request.auth.uid
        && incoming().type in ['image', 'video']
        && incoming().prompt is string
        && incoming().prompt.size() <= 1000
        && incoming().url is string
        && incoming().url.size() <= 2000
        && incoming().createdAt is timestamp
        && incoming().createdAt <= request.time;

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow update: if false; // Generations are immutable
    }
  }
}
